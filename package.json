export default async function handler(req, res) {

  let url = req.query.url;

  if (!url) {

    return res
      .status(400)
      .send("No URL");

  }

  if (
    !url.startsWith("http://") &&
    !url.startsWith("https://")
  ) {

    url = "https://" + url;

  }

  try {

    const response = await fetch(url, {

      headers: {

        "User-Agent":
        "Mozilla/5.0"

      }

    });

    let text =
      await response.text();

    text = text

      .replace(
        /href="\//g,
        `href="${url}/`
      )

      .replace(
        /src="\//g,
        `src="${url}/`
      )

      .replace(
        /action="\//g,
        `action="${url}/`
      );

    res.setHeader(
      "Content-Type",
      "text/html"
    );

    res.setHeader(
      "Access-Control-Allow-Origin",
      "*"
    );

    res.status(200).send(text);

  } catch(err){

    console.error(err);

    res.status(500).send(`

    <html>

    <body style="
      background:#111;
      color:white;
      font-family:sans-serif;
      text-align:center;
      padding-top:100px;
    ">

    <h1>
    Proxy Error
    </h1>

    <p>
    ${err}
    </p>

    </body>

    </html>

    `);

  }

}
